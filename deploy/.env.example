#############################################
# WhatsApp AI Seller Bot - Environment Config
# Copy this to .env and fill in your values
#############################################

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
DEBUG=false
SAFE_MODE=false

# ============================================
# SUPABASE DATABASE
# Get from: https://supabase.com/dashboard
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ============================================
# REDIS (Docker internal network)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# WHATSAPP CLOUD API
# Get from: https://developers.facebook.com/apps/
# 1. Create App -> Business -> WhatsApp
# 2. WhatsApp -> API Setup
# ============================================
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_123

# ============================================
# GEMINI LLM
# Get from: https://aistudio.google.com/apikey
# ============================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# ============================================
# LANCEDB (Vector Database)
# ============================================
LANCEDB_PATH=/app/data/lancedb

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

# ============================================
# SECURITY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================
JWT_SECRET_KEY=change_this_to_random_64_char_string

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_ANALYTICS=true
ENABLE_ABANDONED_CART=true
ENABLE_RECOMMENDATIONS=true

# ============================================
# MONITORING (Optional)
# ============================================
ENABLE_METRICS=true
METRICS_PORT=9090
