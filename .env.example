# ==================================
# ENVIRONMENT
# ==================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
SAFE_MODE=false

# ==================================
# SUPABASE DATABASE
# ==================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: Direct PostgreSQL connection
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ==================================
# REDIS
# ==================================
REDIS_HOST=localhost  # Use 'redis' in Docker
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no password
REDIS_DB=0
# Alternative: Full Redis URL
# REDIS_URL=redis://localhost:6379/0

# ==================================
# WHATSAPP
# ==================================
WHATSAPP_WEBHOOK_URL=http://localhost:8000/webhook
WHATSAPP_WEBHOOK_SECRET=  # For Meta Cloud API verification (optional)

# ==================================
# GEMINI LLM
# ==================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024
GEMINI_TOKEN_LIMIT_PER_REQUEST=4000

# ==================================
# LANCEDB
# ==================================
LANCEDB_PATH=./data/lancedb

# ==================================
# RATE LIMITING
# ==================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

# ==================================
# IDEMPOTENCY
# ==================================
IDEMPOTENCY_TTL=86400  # 24 hours in seconds

# ==================================
# FEATURE FLAGS
# ==================================
ENABLE_ANALYTICS=true
ENABLE_ABANDONED_CART=true
ENABLE_RECOMMENDATIONS=true

# ==================================
# SECURITY
# ==================================
JWT_SECRET_KEY=change-this-to-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================================
# SERVER
# ==================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DASHBOARD_PORT=8501

# ==================================
# MONITORING
# ==================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ==================================
# LOGGING
# ==================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json or text

# ==================================
# CORS
# ==================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ==================================
# BACKUP (Optional - AWS S3)
# ==================================
BACKUP_ENABLED=false
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ==================================
# GRAFANA (Optional)
# ==================================
GRAFANA_PASSWORD=admin
